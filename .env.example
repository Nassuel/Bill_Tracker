# ─── Car Payment (update LOGIN_URL in scraper to match your lender) ──────────
CAR_PAYMENT_USERNAME=
CAR_PAYMENT_PASSWORD=

# ─── Mortgage (update LOGIN_URL in scraper to match your lender) ─────────────
MORTGAGE_USERNAME=
MORTGAGE_PASSWORD=

# ─── Car & Home Insurance (Umbrella Policy) ──────────────────────────────────
INSURANCE_USERNAME=
INSURANCE_PASSWORD=
# Full URL to your insurer's login page (e.g. https://account.allstate.com/anon/login/login.aspx)
INSURANCE_LOGIN_URL=

# ─── Waste Management API (optional — found in browser DevTools Network tab) ──
